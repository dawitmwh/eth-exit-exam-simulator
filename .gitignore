# ==========================================
# 1. Python / Django Exclusions
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments (CRITICAL: keeps venv out of GitHub)
venv/
vmetenv/
ENV/
env.bak/
venv.bak/

# Django specific media and static local collections
# (Kept locally during development; your production will use Cloudinary/CDNs)
backend/staticfiles/
backend/media/

# ==========================================
# 2. JavaScript / Node / Next.js Exclusions
# ==========================================
# Dependencies (CRITICAL: keeps heavy node_modules out of GitHub)
node_modules/
/frontend/node_modules/

# Next.js build output
.next/
/frontend/.next/
out/

# Testing & coverage artifacts
coverage/
.nyc_output/

# Lerna / Turbo repo build caches (if you scale later)
.turbo/

# ==========================================
# 3. Environment Variables & Secrets (CRITICAL)
# ==========================================
# Never commit raw credentials, Chapa/Telebirr API keys, or DB passwords
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
backend/.env
frontend/.env

# Allow committing template example files safely
!.env.example

# ==========================================
# 4. Database & Log Exclusions
# ==========================================
# Even though you use Postgres for dev/prod, safe-guarding SQLite just in case
*.log
*.sqlite3
*.sqlite3-journal

# ==========================================
# 5. OS & IDE System Files
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Ehthumbs.db
[Dd]esktop.ini

# IDEs and Editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

